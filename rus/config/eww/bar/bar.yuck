;; ============================================================================
;; Left Section Widgets
;; ============================================================================

(defwidget launcher []
	(box :class "lnchr" :orientation "h" :space-evenly true :halign "start"
		(button  :onclick "pgrep rofi && pkill rofi || ~/.config/rofi/launcher.sh" :tooltip "меню" 
			(box :space-evenly false
			   (image :path alt :image-height 18 :preserve-aspect-ratio true)
			   (label :text " ${USER}")
      )
    )
	)
)

(defwidget lbgz []
  (box :class "bg" :orientation "h" :space-evenly true :halign "start"
    (button :onclick "./scripts/change-wall.sh zoom" :tooltip "обновить обои" "")
  )
)
      
(defwidget lbg []
  (box :class "bg" :orientation "h" :space-evenly true :halign "start"
    (button :onclick "./scripts/change-wall.sh no-zoom" :tooltip "обновить обои" "")
  )
)
      
(defwidget bg []
  (box :class "bg" :orientation "h" :space-evenly true :halign "start"
    (button :onclick "./scripts/change-wall.sh stat" :tooltip "обновить обои" "")
  )
)

(defwidget wpbg []
  (box :class "bg" :orientation "h" :space-evenly true :halign "start"
    (button :onclick "./scripts/change-wall.sh engine" :tooltip "обновить обои" "")
  )
)

(defwidget hbg []
  (box :class "bg" :orientation "h" :space-evenly true :halign "start"
    (button :onclick "./scripts/change-wall.sh hyprlax" :tooltip "обновить обои" "")
  )
)

(defwidget wallpicker-toggle []
  (box :class "bg"
    (button :onclick "eww open --toggle wallpaper-picker" "")
  )
)

(defvar wall_mode "stat")

(defpoll wallpapers 
  :interval "30s"
  :initial "[]"
  `./scripts/wallpaper-picker.sh list`)

;; ============================================================================
;; Center Section Widgets
;; ============================================================================

(defwidget weather []
  (box :class "tme" :orientation "h" :space-evenly true :halign "start"
    (button :tooltip "лкм: октрыть погоду" :onclick "./scripts/popup.sh wthr" "${wther.icon} ${wther.temp}°C")
  )
)

(defwidget time []
  (box :class "tme" :orientation "h" :space-evenly false :halign "center"
    (button :onclick "./scripts/timed t-d" :onrightclick "./scripts/popup.sh cal" :tooltip "лкм: переключение время - дата, пкм: открыть календарь"
      (box :space-evenly false
        (label :class "lbl-clr" :text "󱑎 ")
        (label :text time_data)
      )
    )
  )
)

;; ============================================================================
;; Right Section Widgets
;; ============================================================================

(defwidget cava []
  (box :class "cava" :vexpand false :hexpand false :space-evenly false
    (label :text CAVA)
  )
)

(defwidget music []
  (eventbox :onscroll "if [ '{}' == 'up' ]; then playerctl next; else playerctl previous; fi"
		(box :class "msc" :style "background-image: url('${music.art}')" :orientation "h" :space-evenly false :halign "end"
	 	  (button :onclick "playerctl play-pause" :onrightclick "./scripts/popup.sh plr" :tooltip "музыка, лкм: играть/остановить, пкм: открыть плеер, прокрутка вверх: след., прокрутка вниз: пред."
        (box :orientation "h" :space-evenly false
          (label :text "${music.status} " :class "lbl-clr")
          (label :text {music.artist} :limit-width 15)
          (label :text "   ")
          (label :text {music.title} :limit-width 35)
        )
      )
		)
	)
)

(defwidget settings []
  (eventbox :onhover "eww update stngs=true" :onhoverlost "eww update stngs=false"
    (box :class "stngs" :orientation "h" :space-evenly false :vexpand false
      (revealer :transition "slideleft" :reveal stngs
        (box :orientation "h" :space-evenly false :vexpand false 
          (button :onclick "bash <(pwvucontrol)" :tooltip "настройки звука" "󰗅")
          (button :onclick "bash <(kitty nmtui)" :tooltip "настройки сети" "󰈀") 
          (button :onclick "bash <(blueman-manager)" :tooltip "настройки bluetooth" "󰂯")
        )
      )
      (label :text "  ")
    )
  )
)

(defwidget power []
  (box :class "pwr" :orientation "h" :space-evenly false :halign "end"
    (button :onclick "eww open --toggle power_pc" :onrightclick "eww open --toggle dashboard":tooltip "лкм: питание | пкм: dashboard" "")
  )
)

(defwidget volume []
  (eventbox :onscroll "if [ '{}' == 'up' ]; then pamixer -i 5; else pamixer -d 5; fi" :vexpand true :valign "fill"
    (box :class "vlm" :orientation "h" :space-evenly false :valign "fill" :vexpand false :tooltip "громкость"
      (label :class "lbl-clr" :text "${volume.sign} ")
      (label :text "${volume.vol}%")
    )
  )
)

;; ============================================================================
;; calendar
;; ============================================================================

(defwidget cal []
  (box :orientation "v" :space-evenly false
    (revealer :transition "slidedown" :reveal cal_inf
      (eventbox :onhoverlost "eww update cal_inf=false & ./scripts/cal reset"
        (box :orientation "v" :class "cal" :spacing 3
          (box :class "cal_wkds"
            (label :text "пн")
            (label :text "вт")
            (label :text "ср")
            (label :text "чт")
            (label :text "пт")
            (label :text "сб" :style "color: #e4413a;")
            (label :text "вс" :style "color: #e4413a;")
          )
          (box
            (label :tooltip {cal.Days.day0.holiday} :text {cal.Days.day0.day} :class "cal ${cal.Days.day0.style}")
            (label :tooltip {cal.Days.day1.holiday} :text {cal.Days.day1.day} :class "cal ${cal.Days.day1.style}")
            (label :tooltip {cal.Days.day2.holiday} :text {cal.Days.day2.day} :class "cal ${cal.Days.day2.style}")
            (label :tooltip {cal.Days.day3.holiday} :text {cal.Days.day3.day} :class "cal ${cal.Days.day3.style}")
            (label :tooltip {cal.Days.day4.holiday} :text {cal.Days.day4.day} :class "cal ${cal.Days.day4.style}")
            (label :tooltip {cal.Days.day5.holiday} :text {cal.Days.day5.day} :class "cal ${cal.Days.day5.style}")
            (label :tooltip {cal.Days.day6.holiday} :text {cal.Days.day6.day} :class "cal ${cal.Days.day6.style}")
          )
          (box
            (label :tooltip {cal.Days.day7.holiday} :text {cal.Days.day7.day} :class "cal ${cal.Days.day7.style}")
            (label :tooltip {cal.Days.day8.holiday} :text {cal.Days.day8.day} :class "cal ${cal.Days.day8.style}")
            (label :tooltip {cal.Days.day9.holiday} :text {cal.Days.day9.day} :class "cal ${cal.Days.day9.style}")
            (label :tooltip {cal.Days.day10.holiday} :text {cal.Days.day10.day} :class "cal ${cal.Days.day10.style}")
            (label :tooltip {cal.Days.day11.holiday} :text {cal.Days.day11.day} :class "cal ${cal.Days.day11.style}")
            (label :tooltip {cal.Days.day12.holiday} :text {cal.Days.day12.day} :class "cal ${cal.Days.day12.style}")
            (label :tooltip {cal.Days.day13.holiday} :text {cal.Days.day13.day} :class "cal ${cal.Days.day13.style}")
          )

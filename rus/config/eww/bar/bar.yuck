            (label :tooltip {cal.Days.day15.holiday} :text {cal.Days.day15.day} :class "cal ${cal.Days.day15.style}")
            (label :tooltip {cal.Days.day16.holiday} :text {cal.Days.day16.day} :class "cal ${cal.Days.day16.style}")
            (label :tooltip {cal.Days.day17.holiday} :text {cal.Days.day17.day} :class "cal ${cal.Days.day17.style}")
            (label :tooltip {cal.Days.day18.holiday} :text {cal.Days.day18.day} :class "cal ${cal.Days.day18.style}")
            (label :tooltip {cal.Days.day19.holiday} :text {cal.Days.day19.day} :class "cal ${cal.Days.day19.style}")
            (label :tooltip {cal.Days.day20.holiday} :text {cal.Days.day20.day} :class "cal ${cal.Days.day20.style}")

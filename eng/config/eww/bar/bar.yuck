;; ============================================================================
;; music player
;; ============================================================================

(defwidget player []
  (box :orientation "v" :space-evenly false
    (revealer :transition "slidedown" :reveal plr_inf
      (box :orientation "h" :space-evenly false :class "plr"
        (box :class "plr-art" :style "background-image: url('${music.art}');")
        (box :orientation "v" :space-evenly true :spacing 6 :class "plr-inf"
          (label :text {music.title} :limit-width 20)
          (label :text {music.artist} :limit-width 20)
          (box :orientation "h" :spacing 3 :space-evenly true :class "plr-nav"
            (button :onclick "playerctl previous" "ůįíģ")
            (button :onclick "playerctl play-pause" "${music.status}")
            (button :onclick "playerctl next" "ůįí≠")
          )
        )
      )
    )
  )
)

;; ============================================================================
;; weather
;; ============================================================================

(defwidget weather_wid []
  (box :orientation "v" :space-evenly false
    (revealer :transition "slidedown" :reveal wthr_inf
      (eventbox :onhoverlost "eww update wthr_inf=false"
        (box :orientation "v" :space-evenly false :class "wther" :spacing 5
          (box :space-evenly false :orientation "v" :style "padding: 12px 12px 0px 12px"
            (box :space-evenly false :spacing 130
              (label :justify "left" :text "–Ę–ĺ–ľ—Ā–ļ")
              (label :class "gray_wthr" :text "–ě–Ī–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ĺ ${wther.updated}")
            )
            (box :space-evenly false :spacing 75
              (box :orientation "v"  :space-evenly false :halign "start"
                (label :text "${wther.temp}¬į" :class "big_wthr_clr")
                (label :lines 3 :limit-width 15 :justify "left" :text {wther.desc})
              )
              (box :orientation "v" :space-evenly false
                (label :text {wther.icon} :class "big_wthr")
              )
            )
            (box :space-evenly false :spacing 25 :class "gray_wthr" :halign "start"
              (box :orientation "v" :halign "start"
                (label :text "–ě—Č—É—Č–į–Ķ—ā—Ā—Ź ${wther.feels}¬į")
                (label :text "–í–Ľ–į–∂–Ĺ–ĺ—Ā—ā—Ć ${wther.humidity}%")
              )
              (box :orientation "v" :halign "start"
                (label :text "–í–Ķ—ā–Ķ—Ä ${wther.wind} –ľ/—Ā")
                (label :text "–Ē–į–≤. ${wther.pressure} –ľ–ľ —Ä—ā.—Ā—ā.")
              )
            )
          )
          (box :class "week_wthr"
            (scroll :hscroll true :vscroll false
              (box :spacing 30
                (box :orientation "v"
                  (label :text {wther.forecast[0].day})
                  (label :class "mid_wthr" :text {wther.forecast[0].icon})
                  (label :class "gray_wthr" :text "${wther.forecast[0].max}/${wther.forecast[0].min}")
                )
                (box :orientation "v"
                  (label :text {wther.forecast[1].day})
                  (label :class "mid_wthr" :text {wther.forecast[1].icon})
                  (label :class "gray_wthr" :text "${wther.forecast[1].max}/${wther.forecast[1].min}")
                )
                (box :orientation "v"
                  (label :text {wther.forecast[2].day})
                  (label :class "mid_wthr" :text {wther.forecast[2].icon})
                  (label :class "gray_wthr" :text "${wther.forecast[2].max}/${wther.forecast[2].min}")
                )
                (box :orientation "v"
                  (label :text {wther.forecast[3].day})
                  (label :class "mid_wthr" :text {wther.forecast[3].icon})
                  (label :class "gray_wthr" :text "${wther.forecast[3].max}/${wther.forecast[3].min}")
                )
                (box :orientation "v"
                  (label :text {wther.forecast[4].day})
                  (label :class "mid_wthr" :text {wther.forecast[4].icon})
                  (label :class "gray_wthr" :text "${wther.forecast[4].max}/${wther.forecast[4].min}")
                )
              )
            )
          )
        )
      )
    )
  )     
)

;; ============================================================================
;; wallpaper picker
;; ============================================================================

(defwidget wall-picker []

  (box 
    :class "wallpicker"
    :orientation "v"
    :space-evenly false
    
    ; Header
    (box 
      :class "header"
      :spacing 3
      :space-evenly false
      
      (label 
        :class "title" 
        :text "Wallpaper Library" 
        :xalign 0 
        :hexpand true
      )
      
      (button 
        :class "icon-btn"
        :tooltip "Refresh cache"
        :onclick "./scripts/wallpaper-picker.sh clean-cache && ./scripts/wallpaper-picker.sh cache-all &"
        "Refresh"
      )
      
      (button 
        :class "close-btn"
        :onclick "eww close wallpaper-picker"
        "X"
      )
    )
    
    (box :class "separator")
    
    ; Mode selector
    (box 
      :class "mode-selector"
      :spacing 3
      :space-evenly false
      :halign "end"
      
      (button 
        :class "mode-btn ${wall_mode == 'stat' ? 'active' : ''}"
        :onclick "eww update wall_mode=stat"
        "Static"
      )
      
      (button 
        :class "mode-btn ${wall_mode == 'zoom' ? 'active' : ''}"
        :onclick "eww update wall_mode=zoom"
        "Zoom"
      )
      
      (button 
        :class "mode-btn ${wall_mode == 'no-zoom' ? 'active' : ''}"
        :onclick "eww update wall_mode=no-zoom"
        "Full"
      )
    )
    
    ; Wallpaper grid —Ā –Ņ—Ä–ĺ–ļ—Ä—É—ā–ļ–ĺ–Ļ
    (scroll 
  :vscroll true
  :hscroll false
  :vexpand true
  :height "100%"

  (box 
    :class "wall-container"
    :orientation "v"
    :spacing 3
    :space-evenly false

    (for row in wallpapers
      (box :class "wall-row" :orientation "h" :spacing 3 :space-evenly false
        (for wall in {row.row}
          (button
            :class "wall-card ${wall.type}"
            :onclick "bash -c 'eww close wallpaper-picker; ~/.config/eww/scripts/wallpaper-picker.sh set \"${wall.path}\" ${wall_mode} &' &"
            :tooltip "${wall.name}"
            :style "min-width: 220px; margin: 0px;"

            (box :orientation "v" :space-evenly false
              (box :class "wall-thumb" :style "background-image: url('${wall.thumb}');")
              (label :class "wall-name" :limit-width 20 :text "${wall.name}")
              (revealer :reveal "${wall.type == 'video'}" :transition "slidedown"
                (label :class "badge" :text "VIDEO")
              )
            )
          )
        )
      )
    )
  )
)
  )
)

;; ============================================================================
;; Window Definition
;; ============================================================================

(defwindow mycal
	:monitor 0
  :stacking "fg"
  :windowtype "normal"
	:geometry (geometry :anchor "top center"
						          :width "380px" 
						          :height "0px")
	(cal)
)

(defwindow weather
	:monitor 0
  :stacking "fg"
  :windowtype "normal"
	:geometry (geometry :anchor "top center"
						          :width "300px" 
						          :height "0px")
	(weather_wid)
)

(defwindow player
	:monitor 0
  :stacking "fg"
  :windowtype "normal"
	:geometry (geometry :anchor "top right"
                      :x "6px"
                      ; :y "-8px"
						          :width "350px" 
						          :height "0px")
	(player)
)
(defwindow wallpaper-picker
  :monitor 0
  :geometry (geometry :width "942px"
                      :height "55%")
  :anchor "center"
  :stacking "overlay"
  :focusable true
  (wall-picker)
)

;; ============================================================================
;; Left Section Widgets
;; ============================================================================

(defwidget launcher []
	(box :class "lnchr" :orientation "h" :space-evenly true :halign "start"
		(button  :onclick "pgrep rofi && pkill rofi || ~/.config/rofi/launcher.sh" :tooltip "–ľ–Ķ–Ĺ—é" 
			(box :space-evenly false
			   (image :path nix :image-height 18 :preserve-aspect-ratio true)
			   (label :text "ÓįÉ ÓįÉ${USER}")
      )
    )
	)
)
      
(defvar wall_mode "stat")

(defpoll wallpapers 
  :interval "30s"
  :initial "[]"
  `./scripts/wallpaper-picker.sh list`)

;; ============================================================================
;; Center Section Widgets
;; ============================================================================

(defwidget weather []
  (box :class "tme" :orientation "h" :space-evenly true :halign "start"
    (button :tooltip "–Ľ–ļ–ľ: –ĺ–ļ—ā—Ä—č—ā—Ć –Ņ–ĺ–≥–ĺ–ī—É" :onclick "./scripts/popup.sh wthr" "${wther.icon} ${wther.temp}¬įC")
  )
)

(defwidget time []
  (box :class "tme" :orientation "h" :space-evenly false :halign "center"
    (button :onclick "./scripts/timed.sh t-d" :onrightclick "./scripts/popup.sh cal" :tooltip "–Ľ–ļ–ľ: –Ņ–Ķ—Ä–Ķ–ļ–Ľ—é—á–Ķ–Ĺ–ł–Ķ –≤—Ä–Ķ–ľ—Ź - –ī–į—ā–į, –Ņ–ļ–ľ: –ĺ—ā–ļ—Ä—č—ā—Ć –ļ–į–Ľ–Ķ–Ĺ–ī–į—Ä—Ć"
      (box :space-evenly false
        (label :class "lbl-clr" :text "ůĪĎé ")
        (label :text time_data)
      )
    )
  )
)

;; ============================================================================
;; Right Section Widgets
;; ============================================================================

(defwidget cava []
  (box :class "cava" :vexpand false :hexpand false :space-evenly false
    (label :text CAVA)
  )
)

(defwidget music []
  (eventbox :onscroll "if [ '{}' == 'up' ]; then playerctl next; else playerctl previous; fi"
		(box :class "msc" :style "background-image: url('${music.art}')" :orientation "h" :space-evenly false :halign "end"
	 	  (button :onclick "playerctl play-pause" :onrightclick "./scripts/popup.sh plr" :tooltip "–ľ—É–∑—č–ļ–į, –Ľ–ļ–ľ: –ł–≥—Ä–į—ā—Ć/–ĺ—Ā—ā–į–Ĺ–ĺ–≤–ł—ā—Ć, –Ņ–ļ–ľ: –ĺ—ā–ļ—Ä—č—ā—Ć –Ņ–Ľ–Ķ–Ķ—Ä, –Ņ—Ä–ĺ–ļ—Ä—É—ā–ļ–į –≤–≤–Ķ—Ä—Ö: —Ā–Ľ–Ķ–ī., –Ņ—Ä–ĺ–ļ—Ä—É—ā–ļ–į –≤–Ĺ–ł–∑: –Ņ—Ä–Ķ–ī."
        (box :orientation "h" :space-evenly false
          (label :text "${music.status}ÓįÉ " :class "lbl-clr")
          (label :text {music.artist} :limit-width 15)
          (label :text "ÓįÉ   ÓįÉ")
          (label :text {music.title} :limit-width 35)
        )
      )
		)
	)
)

(defwidget settings []
  (eventbox :onhover "eww update stngs=true" :onhoverlost "eww update stngs=false"
    (box :class "stngs" :orientation "h" :space-evenly false :vexpand false
      (revealer :transition "slideleft" :reveal stngs
        (box :orientation "h" :space-evenly false :vexpand false 
          (button :onclick "bash <(pavucontrol)" :tooltip "–Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł –∑–≤—É–ļ–į" "ůįóÖÓįÉÓįÉ")
          (button :onclick "bash <(kitty nmtui)" :tooltip "–Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł —Ā–Ķ—ā–ł" "ůįąÄÓįÉÓįÉ") 
          (button :onclick "bash <(blueman-manager)" :tooltip "–Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł bluetooth" "ůįāĮÓįÉ")
        )
      )
      (label :text "ÓįÉ Óęł ÓįÉ")
    )
  )
)

(defwidget power []
  (box :class "pwr" :orientation "h" :space-evenly false :halign "end"
    (button :onclick "eww open --toggle power_pc" :onrightclick "eww open --toggle dashboard":tooltip "–Ľ–ļ–ľ: –Ņ–ł—ā–į–Ĺ–ł–Ķ | –Ņ–ļ–ľ: dashboard" "ÔąĄ")
  )
)

(defwidget volume []
  (eventbox :onscroll "if [ '{}' == 'up' ]; then pamixer -i 5; else pamixer -d 5; fi" :vexpand true :valign "fill"
    (box :class "vlm" :orientation "h" :space-evenly false :valign "fill" :vexpand false :tooltip "–≥—Ä–ĺ–ľ–ļ–ĺ—Ā—ā—Ć"
      (label :class "lbl-clr" :text "${volume.sign} ")
      (label :text "${volume.vol}%")
    )
  )
)

;; ============================================================================
;; calendar
;; ============================================================================

(defwidget cal []
  (box :orientation "v" :space-evenly false
    (revealer :transition "slidedown" :reveal cal_inf
      (eventbox :onhoverlost "eww update cal_inf=false & ./scripts/cal.sh reset"
        (box :orientation "v" :class "cal" :spacing 3
          (box :class "cal_wkds"
            (label :text "–Ņ–Ĺ")
            (label :text "–≤—ā")
            (label :text "—Ā—Ä")
            (label :text "—á—ā")
            (label :text "–Ņ—ā")
            (label :text "—Ā–Ī" :style "color: #e4413a;")
            (label :text "–≤—Ā" :style "color: #e4413a;")
          )
          (box
            (label :text {cal.day0.day} :class "cal ${cal.day0.style}")
            (label :text {cal.day1.day} :class "cal ${cal.day1.style}")
            (label :text {cal.day2.day} :class "cal ${cal.day2.style}")
            (label :text {cal.day3.day} :class "cal ${cal.day3.style}")
            (label :text {cal.day4.day} :class "cal ${cal.day4.style}")
            (label :text {cal.day5.day} :class "cal ${cal.day5.style}")
            (label :text {cal.day6.day} :class "cal ${cal.day6.style}")
          )
          (box
